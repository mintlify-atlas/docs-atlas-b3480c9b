  "keyFeatures": [
    "Member and user management with detailed contact information and membership control",
    "Activity scheduling and monitoring with instructor assignments",
    "Project tracking with budget control, document management, and funding sources",
    "Association configuration including board management, banking, and donations",
    "Integrated messaging system for individual and mass email communications",
    "Dashboard with statistics and analytics",
    "Role-based access control with JWT authentication",
    "Dark/light mode support with responsive mobile-first design",
    "Docker-based deployment with Vue.js frontend and NestJS backend"
  ],
  "publicApiSurface": [
    "POST /auth/register - User registration",
    "POST /auth/login - User authentication",
    "POST /auth/refresh - Token refresh",
    "GET /auth/me - Get current user profile",
    "GET /users - Get all users",
    "POST /users - Create new user",
    "POST /users/edit - Edit existing user",
    "POST /users/delete - Delete user",
    "GET /activities - Get all activities",
    "POST /activities - Create new activity",
    "PUT /activities/:id - Update activity",
    "DELETE /activities/:id - Delete activity",
    "GET /projects - Get all projects",
    "POST /projects - Create new project with PDF uploads",
    "PUT /projects/:id - Update project",
    "DELETE /projects/:id - Delete project",
    "GET /configuracion/datos - Get association data",
    "PUT /configuracion/datos - Update association data",
    "GET /configuracion/junta - Get board members",
    "POST /configuracion/junta - Add board member",
    "GET /configuracion/bancos - Get bank accounts",
    "POST /configuracion/bancos - Add bank account",
    "GET /configuracion/donativos - Get donations",
    "POST /configuracion/donativos - Add donation",
    "POST /mail/send - Send email to specific recipients",
    "POST /mail/send-all - Send email to all members",
    "GET /stats - Get dashboard statistics"
  ]
}
